{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "strict": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "skipLibCheck": true,
        "noEmit": true,
        "isolatedModules": true,
        "resolveJsonModule": true,
        "types": ["jquery"]
    },
    "include": ["resources/src/js/**/*.ts", "resources/js/**/*.ts", "resources/src/js/**/*.d.ts"]
}
