{
    "name": "tipowerup/ti-theme-orange-tw",
    "type": "tastyigniter-package",
    "description": "Minimal TastyIgniter theme template with Tailwind CSS and Vite",
    "license": "MIT",
    "authors": [
        {
            "name": "TiPowerUp"
        }
    ],
    "keywords": [
        "tastyigniter",
        "theme",
        "orange",
        "tailwind",
        "vite"
    ],
    "require": {
        "livewire/livewire": "^v3.0",
        "spatie/laravel-google-fonts": "^1.2",
        "tastyigniter/core": "^v4.0",
        "tipowerup/ti-theme-toolkit": "*",
        "tastyigniter/ti-ext-cart": "^v4.0",
        "tastyigniter/ti-ext-coupons": "^v4.0",
        "tastyigniter/ti-ext-frontend": "^v4.0",
        "tastyigniter/ti-ext-local": "^v4.0",
        "tastyigniter/ti-ext-pages": "^v4.0",
        "tastyigniter/ti-ext-payregister": "^v4.0",
        "tastyigniter/ti-ext-reservation": "^v4.0",
        "tastyigniter/ti-ext-socialite": "^v4.0",
        "tastyigniter/ti-ext-user": "^v4.0"
    },
    "require-dev": {
        "laravel/pint": "^1.2",
        "mockery/mockery": "^1.6",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "tipowerup/testbench": "^0.1"
    },
    "autoload": {
        "psr-4": {
            "TiPowerUp\\OrangeTw\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TiPowerUp\\OrangeTw\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test:lint": "vendor/bin/pint --test --ansi",
        "test:lint-fix": "vendor/bin/pint --ansi",
        "test:pest": "vendor/bin/pest --compact",
        "test": [
            "@test:lint",
            "@test:pest"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "TiPowerUp\\OrangeTw\\ServiceProvider"
            ]
        },
        "tastyigniter-theme": {
            "code": "tipowerup-orange-tw",
            "name": "Orange TW Theme",
            "locked": false,
            "source-path": "/resources/views",
            "meta-path": "/resources/meta",
            "publish-paths": [
                "/public"
            ],
            "require": {
                "igniter.cart": "*",
                "igniter.coupons": "*",
                "igniter.frontend": "*",
                "igniter.local": "*",
                "igniter.pages": "*",
                "igniter.payregister": "*",
                "igniter.reservation": "*",
                "igniter.socialite": "*",
                "igniter.user": "*"
            }
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../ti-theme-toolkit",
            "options": {
                "symlink": true
            }
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/installers": true,
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    }
}
